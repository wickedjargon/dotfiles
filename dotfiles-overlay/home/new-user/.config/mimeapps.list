[Default Applications]
# --- Text files: open everything text-like in emacs-client ---
# mimeapps.list has no text/* wildcard, so structured-text formats (which carry
# their own MIME type instead of falling back to text/plain) are listed here.
# Plain text and markup
text/plain=emacs-client.desktop
text/markdown=emacs-client.desktop
text/x-markdown=emacs-client.desktop
text/x-rst=emacs-client.desktop
text/x-org=emacs-client.desktop
text/asciidoc=emacs-client.desktop
text/troff=emacs-client.desktop
text/x-readme=emacs-client.desktop
text/x-tex=emacs-client.desktop
text/x-bibtex=emacs-client.desktop
application/x-latex=emacs-client.desktop
