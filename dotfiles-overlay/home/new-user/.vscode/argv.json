// This configuration file allows you to pass permanent command line arguments to VS Code.
// Only a subset of arguments is currently supported to reduce the likelihood of breaking
// the installation.
//
// NOTE: Changing this file requires a restart of VS Code.
{
	// Store secrets in an encrypted local file instead of the OS keyring.
	// Suppresses the "OS keyring is not available" warning on this
	// startx / no-display-manager setup. gnome-keyring is still installed
	// and unlocked at login (see dotfiles-patches/etc/pam.d/login) for any
	// other libsecret-based apps.
	"password-store": "basic",
	"enable-crash-reporter": true,
}
