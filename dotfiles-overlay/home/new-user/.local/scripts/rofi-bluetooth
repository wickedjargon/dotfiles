#!/bin/sh
# rofi-bluetooth — Bluetooth device management with Alt+c to copy command.

selection=$(printf "Connect Nothing\nDisconnect Nothing\nReconnect Nothing\nProfile Nothing Hands Free Unit\nProfile Nothing A2DP Sink\nConnect Musicozy\nDisconnect Musicozy\nConnect Miniroll\nDisconnect Miniroll" | rofi -dmenu -i -p "Bluetooth" -kb-custom-1 "Alt+c")
exit_code=$?

[ $exit_code -eq 1 ] && exit 0
[ -z "$selection" ] && exit 0

case "$selection" in
    'Connect Nothing') cmd='bluetooth-connect "3C:B0:ED:A7:6A:88" "Nothing Headphone (1)"' ;;
    'Disconnect Nothing') cmd='bluetooth-disconnect "3C:B0:ED:A7:6A:88" "Nothing Headphone (1)"' ;;
    'Reconnect Nothing') cmd='bluetooth-nothing-reconnect' ;;
    'Profile Nothing Hands Free Unit') cmd='bluetooth-set-profile "3C:B0:ED:A7:6A:88" handsfree_head_unit' ;;
    'Profile Nothing A2DP Sink') cmd='bluetooth-set-profile "3C:B0:ED:A7:6A:88" a2dp_sink' ;;
    'Connect Musicozy') cmd='bluetooth-connect "41:42:AB:DD:51:37" "Musicozy"' ;;
    'Disconnect Musicozy') cmd='bluetooth-disconnect "41:42:AB:DD:51:37" "Musicozy"' ;;
    'Connect Miniroll') cmd='bluetooth-connect "10:94:97:3C:C4:41" "Miniroll"' ;;
    'Disconnect Miniroll') cmd='bluetooth-disconnect "10:94:97:3C:C4:41" "Miniroll"' ;;
    *) exit 1 ;;
esac

if [ $exit_code -eq 10 ]; then
    printf '%s' "$cmd" | xclip -selection clipboard
    notify-send "Copied Command" "$cmd"
else
    eval "$cmd"
fi
