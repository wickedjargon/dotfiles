#!/bin/sh
# rofi-run — Run commands from PATH with Alt+c to copy.

selection=$(dmenu_path | rofi -dmenu -i -p "Run" -kb-custom-1 "Alt+c")
exit_code=$?

[ $exit_code -eq 1 ] && exit 0
[ -z "$selection" ] && exit 0

if [ $exit_code -eq 10 ]; then
    printf '%s' "$selection" | xclip -selection clipboard
    notify-send "Copied Command" "$selection"
else
    echo "$selection" | /bin/sh &
fi
