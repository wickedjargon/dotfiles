#!/bin/sh

# Keyboard repeat rate (250ms delay, 30 cps)
xset r rate 250 30

xset -dpms        # disable DPMS (power management)
xset s off        # disable screensaver
xset s off -dpms  # ensure both are off
xset -b           # disable terminal bell

# display cursor when no window is active
xsetroot -cursor_name left_ptr

# Disable the trackpad (BIOS disable only works for PS/2, I2C still passes through)
xinput disable "Elan Touchpad" 2>/dev/null
