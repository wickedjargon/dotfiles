#!/bin/sh
. ~/.config/dmenu/config

delete_wifi_connection() {
    connections=$(nmcli -t -f NAME,TYPE connection show | grep ':802-11-wireless$' | cut -d: -f1)

    if [ -z "$connections" ]; then
        notify-send -u low "No saved connections to delete"
        return
    fi

    selected=$(printf "%s" "$connections" | dmenu $DMENU_BASIC_ARGS -fn "$DMENU_FONT" -i -p "Delete Connection:")
    [ -z "$selected" ] && return

    confirm=$(printf "No\nYes" | dmenu $DMENU_BASIC_ARGS -fn "$DMENU_FONT" -i -p "Delete '$selected'?")

    if [ "$confirm" = "Yes" ]; then
        if nmcli connection delete "$selected" 2>/dev/null; then
            notify-send -u normal "Deleted connection: $selected"
        else
            notify-send -u critical "Failed to delete: $selected"
        fi
    fi
}

case "$(printf "Connect to WiFi Network\nRescan WiFi Networks\nShow Current WiFi Network\nDisconnect from WiFi Network\nDelete WiFi Connection\nShow Password of WiFi Connection\nVPN\nMAC Address" | dmenu $DMENU_BASIC_ARGS -fn "$DMENU_FONT" -i -p 'Internet:')" in
    'Connect to WiFi Network') dmenu-connect-to-network ;;
    'Rescan WiFi Networks') wifi-rescan ;;
    'Show Current WiFi Network') wifi-current-network ;;
    'Disconnect from WiFi Network') wifi-disconnect ;;
    'Delete WiFi Connection') delete_wifi_connection ;;
    'Show Password of WiFi Connection') wifi-show-password ;;
    'VPN') dmenu-vpn ;;
    'MAC Address') dmenu-mac-address ;;
    *) exit 1 ;;
esac
