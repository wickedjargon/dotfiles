#!/usr/bin/env python3
"""Upload the primary X selection to 0x0.st, falling back to u.fftp.io."""

import os
import subprocess
import sys

UPLOAD_URL = "https://u.fftp.io/upload"
API_KEY_FILE = os.path.expanduser("~/.config/u/api_key")


def notify(title, message):
    subprocess.run(["notify-send", title, message])


def get_selection():
    try:
        result = subprocess.run(
            ["xclip", "-o", "-selection", "primary"],
            capture_output=True,
            text=True,
            timeout=2,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout
        return None
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return None


def copy_to_clipboard(text):
    subprocess.run(["xclip", "-selection", "clipboard"], input=text, text=True)


def upload_to_0x0(content):
    try:
        result = subprocess.run(
            [
                "curl", "-fsS",
                "--connect-timeout", "5",
                "--max-time", "30",
                "-F", "file=@-",
                "https://0x0.st",
            ],
            input=content,
            capture_output=True,
            text=True,
        )
        if result.returncode == 0:
            url = result.stdout.strip()
            if url.startswith(("http://0x0.st/", "https://0x0.st/")):
                return url
        return None
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return None


def read_api_key():
    try:
        with open(API_KEY_FILE) as f:
            return f.read().strip()
    except FileNotFoundError:
        return None


def upload_to_u(content):
    api_key = read_api_key()
    if not api_key:
        return None
    try:
        result = subprocess.run(
            [
                "curl", "-fsS",
                "--connect-timeout", "5",
                "--max-time", "30",
                "-H", f"Authorization: Bearer {api_key}",
                "-F", "file=@-;filename=paste.txt",
                UPLOAD_URL,
            ],
            input=content,
            capture_output=True,
            text=True,
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
        return None
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return None


def main():
    content = get_selection()
    if not content:
        notify("Upload Failed", "No text selected")
        sys.exit(1)

    notify("Uploading...", "Uploading selection to 0x0.st")

    url = upload_to_0x0(content)
    if url:
        copy_to_clipboard(url)
        notify("Upload Successful", f"URL copied: {url}")
        return

    notify("0x0.st failed", "Falling back to u.fftp.io...")

    url = upload_to_u(content)
    if url:
        copy_to_clipboard(url)
        notify("Upload Successful", f"URL copied (via u.fftp.io): {url}")
    else:
        notify("Upload Failed", "Both 0x0.st and u.fftp.io failed")
        sys.exit(1)


if __name__ == "__main__":
    main()
