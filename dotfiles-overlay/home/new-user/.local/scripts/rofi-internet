#!/bin/sh
# rofi-internet — Network management with Alt+c to copy command.

delete_wifi_connection() {
    connections=$(nmcli -t -f NAME,TYPE connection show | grep ':802-11-wireless$' | cut -d: -f1)

    if [ -z "$connections" ]; then
        notify-send -u low "No saved connections to delete"
        return
    fi

    selected=$(printf "%s" "$connections" | rofi -dmenu -i -p "Delete Connection:")
    [ -z "$selected" ] && return

    confirm=$(printf "No\nYes" | rofi -dmenu -i -p "Delete '$selected'?")

    if [ "$confirm" = "Yes" ]; then
        if nmcli connection delete "$selected" 2>/dev/null; then
            notify-send -u normal "Deleted connection: $selected"
        else
            notify-send -u critical "Failed to delete: $selected"
        fi
    fi
}

selection=$(printf "Connect to WiFi Network\nRescan WiFi Networks\nShow Current WiFi Network\nDisconnect from WiFi Network\nDelete WiFi Connection\nShow Password of WiFi Connection\nVPN\nMAC Address" | rofi -dmenu -i -p "Internet:" -kb-custom-1 "Alt+c")
exit_code=$?

[ $exit_code -eq 1 ] && exit 0
[ -z "$selection" ] && exit 0

case "$selection" in
    'Connect to WiFi Network') cmd='dmenu-connect-to-network' ;;
    'Rescan WiFi Networks') cmd='wifi-rescan' ;;
    'Show Current WiFi Network') cmd='wifi-current-network' ;;
    'Disconnect from WiFi Network') cmd='wifi-disconnect' ;;
    'Delete WiFi Connection') cmd='delete_wifi_connection' ;;
    'Show Password of WiFi Connection') cmd='wifi-show-password' ;;
    'VPN') cmd='dmenu-vpn' ;;
    'MAC Address') cmd='dmenu-mac-address' ;;
    *) exit 1 ;;
esac

if [ $exit_code -eq 10 ]; then
    printf '%s' "$cmd" | xclip -selection clipboard
    notify-send "Copied Command" "$cmd"
else
    eval "$cmd"
fi
