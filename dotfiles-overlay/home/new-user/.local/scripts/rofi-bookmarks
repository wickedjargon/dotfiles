#!/usr/bin/env python3
# rofi-bookmarks — Copy bookmarks from ~/d/notes/bm.md to clipboard via rofi.

import os
import re
import subprocess
import sys
from pathlib import Path
from urllib.parse import unquote

BOOKMARKS_FILE = Path.home() / "d" / "notes" / "bm.md"


def rofi_select(titles):
    rofi_input = "\n".join(titles)
    cmd = ["rofi", "-dmenu", "-i", "-p", "Bookmark"]
    try:
        result = subprocess.run(
            cmd, input=rofi_input, capture_output=True, text=True, check=True
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        return None


def parse_bookmarks(path):
    entries = []
    title = None
    resource = None

    def commit():
        nonlocal title, resource
        if title and resource:
            entries.append({"title": title, "resource": resource})
        title = None
        resource = None

    with open(path, "r") as f:
        for raw_line in f:
            line = raw_line.strip()

            if line.startswith("# "):
                if title and resource:
                    commit()
                elif title:
                    title = None
                    resource = None
                title = line[2:].strip()

            elif not line:
                if title and resource:
                    commit()

            elif not resource:
                resource = line

    commit()
    return entries


def copy_to_clipboard(text):
    try:
        p = subprocess.Popen(["xclip", "-selection", "clipboard"], stdin=subprocess.PIPE)
        p.communicate(input=text.encode("utf-8"))
    except FileNotFoundError:
        subprocess.run(["notify-send", "Error", "xclip not installed"])


def main():
    if not BOOKMARKS_FILE.exists():
        subprocess.run(["notify-send", "Error", f"Bookmarks file not found: {BOOKMARKS_FILE}"])
        return

    entries = parse_bookmarks(BOOKMARKS_FILE)
    if not entries:
        subprocess.run(["notify-send", "Error", "No bookmarks found"])
        return

    title_to_entry = {}
    titles = []
    for e in entries:
        t = e["title"]
        if t in title_to_entry:
            t = f"{t}  ({e['resource'][:40]})"
        title_to_entry[t] = e
        titles.append(t)

    selected = rofi_select(titles)

    if selected and selected in title_to_entry:
        resource = title_to_entry[selected]["resource"]
        copy_to_clipboard(resource)
        subprocess.run(["notify-send", "Copied", resource])


if __name__ == "__main__":
    main()
