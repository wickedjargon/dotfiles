#!/bin/sh

MAC="3C:B0:ED:A7:6A:88"

# Check if the device is connected
connected=$(timeout 1 bluetoothctl info "$MAC" 2>/dev/null | awk '/Connected:/ {print $2}')

if [ "$connected" = "yes" ]; then
    # Get battery percentage
    battery=$(bluetoothctl info "$MAC" | grep "Battery Percentage" | grep -oP '\(\K[0-9]+')
    if [ -n "$battery" ]; then
        echo "🎧 ${battery}%"
    else
        echo "🎧 ?%"
    fi
elif grep -qi 'Nothing Headphone' /proc/asound/cards; then
    # Wired over USB: kernel registers an ALSA card even with no audio daemon.
    # Battery isn't exposed over USB, so show just the headphone icon.
    echo "🎧"
else
    # Don't show anything when not connected
    echo ""
fi
