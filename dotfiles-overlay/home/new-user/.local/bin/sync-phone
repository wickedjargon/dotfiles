#!/usr/bin/env bash
# sync-phone — rsync ~/d/ dirs to/from phone over Tailscale
# Requires: rsync, ssh, tailscale
# Phone runs Termux with sshd on port 8022

set -euo pipefail

# ── Config ──────────────────────────────────────────────────────────
PHONE_HOST="pixel-8"  # Tailscale MagicDNS hostname
PHONE_PORT=8022
PHONE_BASE="/data/data/com.termux/files/home/storage/shared"

# Directories to sync: local_path -> phone_path
# NOTE: images excludes screenshots/ to avoid overlap (synced separately)
declare -A SYNC_DIRS=(
    ["$HOME/d/audio"]="$PHONE_BASE/Music"
    ["$HOME/d/images"]="$PHONE_BASE/DCIM"
    ["$HOME/d/notes"]="$PHONE_BASE/Notes"
    ["$HOME/d/other"]="$PHONE_BASE/Other"
    ["$HOME/d/images/screenshots"]="$PHONE_BASE/Pictures/Screenshots"
    ["$HOME/d/video"]="$PHONE_BASE/Movies"
)

# Exclude patterns per local dir (to prevent overlapping syncs)
declare -A SYNC_EXCLUDES=(
    ["$HOME/d/images"]="screenshots"
)

# ── Colors ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Defaults ────────────────────────────────────────────────────────
DIRECTION=""
DRY_RUN=false
NO_DELETE=false
LATEST_COUNT=0
NTH=0
FILES=()

# ── Helpers ─────────────────────────────────────────────────────────
info()  { printf "${CYAN}▸${RESET} %s\n" "$*"; }
ok()    { printf "${GREEN}✓${RESET} %s\n" "$*"; }
warn()  { printf "${YELLOW}!${RESET} %s\n" "$*"; }
die()   { printf "${RED}✗${RESET} %s\n" "$*" >&2; exit 1; }
header(){ printf "\n${BOLD}%s${RESET}\n" "$*"; }

# SSH helper — run a command on phone, return output
phone_ssh() { ssh -p "$PHONE_PORT" "$PHONE_HOST" "$@"; }

usage() {
    cat <<'EOF'
Usage: sync-phone <push|pull> [OPTIONS] [FILE...]

Commands:
  push              Laptop → Phone
  pull              Phone → Laptop

File selection (pick one):
  FILE...           Sync files matching these filenames
  --latest [N]      Sync the N most recent files (default: 1)
  --nth N           Sync the Nth most recent file (1 = latest)

Options:
  --dry-run         Show what would be synced without transferring
  --no-delete       Don't delete extraneous files at destination
  -h, --help        Show this help

Examples:
  sync-phone push                   Push all directories
  sync-phone pull                   Pull all directories
  sync-phone push todo.md           Push file matching "todo.md"
  sync-phone pull --latest          Pull the single latest file
  sync-phone pull --latest 3        Pull the 3 most recent files
  sync-phone pull --nth 2           Pull the 2nd most recent file
  sync-phone push --dry-run         Preview a full push
EOF
    exit "${1:-1}"
}

# ── Argument parsing ────────────────────────────────────────────────
parse_args() {
    [[ $# -lt 1 ]] && usage

    # First arg must be push/pull (or --help)
    case "$1" in
        push|--push)  DIRECTION="push" ;;
        pull|--pull)  DIRECTION="pull" ;;
        -h|--help)    usage 0 ;;
        *)            die "Unknown command: $1 (expected push or pull)" ;;
    esac
    shift

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --latest)
                if [[ $# -ge 2 && "$2" =~ ^[0-9]+$ ]]; then
                    LATEST_COUNT="$2"
                    shift
                else
                    LATEST_COUNT=1
                fi
                ;;
            --nth)
                [[ $# -lt 2 ]] && die "--nth requires a number"
                [[ ! "$2" =~ ^[1-9][0-9]*$ ]] && die "--nth requires a positive number, got: $2"
                NTH="$2"
                shift
                ;;
            --dry-run)   DRY_RUN=true ;;
            --no-delete) NO_DELETE=true ;;
            -h|--help)   usage 0 ;;
            -*)          die "Unknown option: $1" ;;
            *)           FILES+=("$1") ;;
        esac
        shift
    done

    # Validation: --latest and --nth are mutually exclusive
    if [[ $LATEST_COUNT -gt 0 && $NTH -gt 0 ]]; then
        die "--latest and --nth cannot be used together"
    fi

    # Validation: file args and --latest/--nth are mutually exclusive
    if [[ ${#FILES[@]} -gt 0 && ($LATEST_COUNT -gt 0 || $NTH -gt 0) ]]; then
        die "Cannot combine filenames with --latest or --nth"
    fi
}

# ── Build rsync options ────────────────────────────────────────────
build_rsync_opts() {
    local -n opts_ref=$1
    local use_delete=${2:-true}

    opts_ref=(-avz --progress -e "ssh -p $PHONE_PORT")

    if [[ "$use_delete" == "true" && "$NO_DELETE" == "false" ]]; then
        opts_ref+=(--delete)
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        opts_ref+=(--dry-run)
    fi
}

# ── Connection check ───────────────────────────────────────────────
check_connection() {
    info "Checking connection to ${BOLD}$PHONE_HOST${RESET}..."
    if ! phone_ssh "echo ok" &>/dev/null; then
        die "Cannot reach $PHONE_HOST. Make sure Tailscale is active and sshd is running in Termux."
    fi
    ok "Phone is reachable"
}

# ── Build remote dirs string for SSH ───────────────────────────────
# Returns a space-separated, single-quoted list of all remote sync dirs
get_remote_dirs() {
    local dirs=""
    for local_dir in "${!SYNC_DIRS[@]}"; do
        dirs+="'${SYNC_DIRS[$local_dir]}' "
    done
    echo "$dirs"
}

# ── Full sync ──────────────────────────────────────────────────────
do_full_sync() {
    local -a rsync_opts
    build_rsync_opts rsync_opts true

    if [[ "$DIRECTION" == "push" ]]; then
        header "PUSHING: Laptop → Phone"
    else
        header "PULLING: Phone → Laptop"
    fi

    local local_dir remote_dir dir_name
    for local_dir in "${!SYNC_DIRS[@]}"; do
        remote_dir="${SYNC_DIRS[$local_dir]}"
        dir_name=$(basename "$local_dir")

        # Build per-directory rsync opts (may include excludes)
        local -a dir_opts=("${rsync_opts[@]}")
        if [[ -n "${SYNC_EXCLUDES[$local_dir]:-}" ]]; then
            dir_opts+=(--exclude "${SYNC_EXCLUDES[$local_dir]}")
        fi

        printf "\n${DIM}─── %s ───${RESET}\n" "$dir_name"

        if [[ "$DIRECTION" == "push" ]]; then
            phone_ssh "mkdir -p '$remote_dir'" 2>/dev/null
            rsync "${dir_opts[@]}" -- "$local_dir/" "$PHONE_HOST:$remote_dir/"
        else
            mkdir -p "$local_dir"
            rsync "${dir_opts[@]}" -- "$PHONE_HOST:$remote_dir/" "$local_dir/"
        fi
    done

    echo ""
    ok "${DIRECTION^} complete."
}

# ── Find files by name ─────────────────────────────────────────────
do_file_sync() {
    local -a rsync_opts
    build_rsync_opts rsync_opts false  # no --delete for individual files

    if [[ "$DIRECTION" == "push" ]]; then
        header "PUSHING files: Laptop → Phone"
    else
        header "PULLING files: Phone → Laptop"
    fi

    local filename
    for filename in "${FILES[@]}"; do
        info "Searching for ${BOLD}$filename${RESET}..."

        local -a matches=()
        local local_dir remote_dir

        if [[ "$DIRECTION" == "push" ]]; then
            # Search locally
            local match
            for local_dir in "${!SYNC_DIRS[@]}"; do
                while IFS= read -r -d '' match; do
                    matches+=("$local_dir|${SYNC_DIRS[$local_dir]}|$match")
                done < <(find "$local_dir" -name "$filename" -type f -print0 2>/dev/null)
            done
        else
            # Search on phone — single SSH call across all remote dirs
            local find_cmd=""
            for local_dir in "${!SYNC_DIRS[@]}"; do
                remote_dir="${SYNC_DIRS[$local_dir]}"
                find_cmd+="find '$remote_dir' -name '$filename' -type f 2>/dev/null | sed 's|^|$local_dir|$remote_dir||'; "
            done

            local line
            while IFS='|' read -r local_dir remote_dir fpath; do
                [[ -z "$fpath" ]] && continue
                matches+=("$local_dir|$remote_dir|$fpath")
            done < <(phone_ssh "$find_cmd" || true)
        fi

        if [[ ${#matches[@]} -eq 0 ]]; then
            warn "No file matching '$filename' found"
            continue
        fi

        if [[ ${#matches[@]} -gt 1 ]]; then
            warn "Multiple matches for '$filename':"
            local m fpath
            for m in "${matches[@]}"; do
                IFS='|' read -r _ _ fpath <<< "$m"
                printf "  ${DIM}%s${RESET}\n" "$fpath"
            done
            warn "Please use a more specific filename"
            continue
        fi

        # Exactly one match
        local found_path rel_path
        IFS='|' read -r local_dir remote_dir found_path <<< "${matches[0]}"

        if [[ "$DIRECTION" == "push" ]]; then
            rel_path="${found_path#"$local_dir/"}"
            local remote_file="$remote_dir/$rel_path"
            phone_ssh "mkdir -p '$(dirname "$remote_file")'" 2>/dev/null
            rsync "${rsync_opts[@]}" -- "$found_path" "$PHONE_HOST:$remote_file"
        else
            rel_path="${found_path#"$remote_dir/"}"
            local local_file="$local_dir/$rel_path"
            mkdir -p "$(dirname "$local_file")"
            rsync "${rsync_opts[@]}" -- "$PHONE_HOST:$found_path" "$local_file"
        fi

        ok "Synced: $filename"
    done
}

# ── Find latest/nth files ──────────────────────────────────────────
do_latest_sync() {
    local count=$1
    local pick_nth=$2  # 0 = use count, >0 = pick specific Nth

    local -a rsync_opts
    build_rsync_opts rsync_opts false  # no --delete for individual files

    if [[ "$DIRECTION" == "push" ]]; then
        header "PUSHING latest files: Laptop → Phone"
    else
        header "PULLING latest files: Phone → Laptop"
    fi

    # Determine how many to fetch from the sorted list
    local fetch_count
    if [[ $pick_nth -gt 0 ]]; then
        fetch_count=$pick_nth
    else
        fetch_count=$count
    fi

    # Collect all files with timestamps
    local -a all_files=()
    local ts fpath line local_dir remote_dir

    if [[ "$DIRECTION" == "push" ]]; then
        # Search locally
        for local_dir in "${!SYNC_DIRS[@]}"; do
            while IFS= read -r line; do
                [[ -z "$line" ]] && continue
                ts="${line%% *}"
                fpath="${line#* }"
                all_files+=("$ts|$local_dir|${SYNC_DIRS[$local_dir]}|$fpath")
            done < <(find "$local_dir" -type f -printf '%T@ %p\n' 2>/dev/null)
        done
    else
        # Search on phone — single SSH call across all remote dirs
        local find_cmd=""
        for local_dir in "${!SYNC_DIRS[@]}"; do
            remote_dir="${SYNC_DIRS[$local_dir]}"
            find_cmd+="find '$remote_dir' -type f -printf '%T@ %p\n' 2>/dev/null | sed 's|^|$local_dir|$remote_dir||'; "
        done

        while IFS='|' read -r local_dir remote_dir ts_and_path; do
            [[ -z "$ts_and_path" ]] && continue
            ts="${ts_and_path%% *}"
            fpath="${ts_and_path#* }"
            all_files+=("$ts|$local_dir|$remote_dir|$fpath")
        done < <(phone_ssh "$find_cmd" || true)
    fi

    if [[ ${#all_files[@]} -eq 0 ]]; then
        warn "No files found in sync directories"
        return
    fi

    # Sort by timestamp (descending) and pick the top N
    local -a sorted
    mapfile -t sorted < <(printf '%s\n' "${all_files[@]}" | sort -t'|' -k1,1 -rn | head -n "$fetch_count")

    # If --nth, take only the last entry (the Nth)
    if [[ $pick_nth -gt 0 ]]; then
        if [[ ${#sorted[@]} -lt $pick_nth ]]; then
            die "Only ${#sorted[@]} files found, cannot get #${pick_nth}"
        fi
        sorted=("${sorted[$((pick_nth - 1))]}")
    fi

    # Sync each selected file
    local entry basename_file rel_path
    for entry in "${sorted[@]}"; do
        IFS='|' read -r _ local_dir remote_dir found_path <<< "$entry"
        basename_file=$(basename "$found_path")

        if [[ "$DIRECTION" == "push" ]]; then
            rel_path="${found_path#"$local_dir/"}"
            local remote_file="$remote_dir/$rel_path"

            info "Syncing ${BOLD}$basename_file${RESET} ${DIM}($rel_path)${RESET}"
            phone_ssh "mkdir -p '$(dirname "$remote_file")'" 2>/dev/null
            rsync "${rsync_opts[@]}" -- "$found_path" "$PHONE_HOST:$remote_file"
        else
            rel_path="${found_path#"$remote_dir/"}"
            local local_file="$local_dir/$rel_path"

            info "Syncing ${BOLD}$basename_file${RESET} ${DIM}($rel_path)${RESET}"
            mkdir -p "$(dirname "$local_file")"
            rsync "${rsync_opts[@]}" -- "$PHONE_HOST:$found_path" "$local_file"
        fi

        ok "Synced: $basename_file"
    done
}

# ── Preflight ───────────────────────────────────────────────────────
preflight() {
    # Tailscale must be running
    if ! tailscale status &>/dev/null; then
        die "Tailscale is not running. Disconnect your VPN first (dmenu-vpn → Disconnect), then try again."
    fi
    check_connection
}

# ── Main ────────────────────────────────────────────────────────────
main() {
    parse_args "$@"
    preflight

    if [[ ${#FILES[@]} -gt 0 ]]; then
        do_file_sync
    elif [[ $LATEST_COUNT -gt 0 ]]; then
        do_latest_sync "$LATEST_COUNT" 0
    elif [[ $NTH -gt 0 ]]; then
        do_latest_sync 0 "$NTH"
    else
        do_full_sync
    fi
}

main "$@"
