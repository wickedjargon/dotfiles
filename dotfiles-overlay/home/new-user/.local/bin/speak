#!/usr/bin/env python3
"""speak - Speak text aloud with edge-tts (Microsoft's online TTS).

Usage:
  speak                 Speak the current selection (the X PRIMARY selection,
                        or the CLIPBOARD when a clipboard-copying app like
                        zathura is focused).
  speak some words      Speak the given words.
  echo hi | speak -     Speak text read from stdin.

Options:
  -u, --unwrap          Undo PDF-style hard line wrapping before speaking, so
                        soft-wrapped lines don't cause pauses mid-sentence.
                        Real paragraph breaks are preserved.

Bound to a key, pressing it again while speaking stops playback (toggle).
The voice can be overridden with the SPEAK_VOICE environment variable, e.g.
  SPEAK_VOICE=en-GB-RyanNeural speak

Requires an internet connection: edge-tts synthesizes the audio server-side.
"""

import os
import re
import signal
import subprocess
import sys
from pathlib import Path
from shutil import which

# If running inside a distrobox container, re-exec on the host so we reach the
# host's X selection and audio rather than the container's.
if os.path.exists("/run/.containerenv"):
    if which("distrobox-host-exec"):
        os.execvp("distrobox-host-exec", ["distrobox-host-exec"] + sys.argv)

VOICE = os.environ.get("SPEAK_VOICE", "en-US-AvaNeural")

# Track the player so a second keypress can stop it.
RUNTIME = os.environ.get("XDG_RUNTIME_DIR") or "/tmp"
PIDFILE = Path(RUNTIME) / "speak.pid"


def notify(msg, urgency="normal"):
    if which("notify-send"):
        subprocess.run(
            ["notify-send", "-u", urgency, "-a", "speak", "speak", msg],
            check=False,
        )
    else:
        print(f"speak: {msg}", file=sys.stderr)


def alive(pid):
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def stop_if_speaking():
    """Stop a still-running speak and return True; clean up stale pidfiles."""
    try:
        pid = int(PIDFILE.read_text().strip())
    except (FileNotFoundError, ValueError):
        return False
    speaking = alive(pid)
    if speaking:
        try:
            os.killpg(pid, signal.SIGTERM)  # kills the shell + edge-tts + mpv
        except ProcessLookupError:
            speaking = False
    PIDFILE.unlink(missing_ok=True)
    return speaking


def active_window_class():
    """Lower-cased WM_CLASS of the focused window, or "" if it can't be read."""
    if not (which("xdotool") and which("xprop")):
        return ""
    try:
        win = subprocess.run(
            ["xdotool", "getactivewindow"], capture_output=True, text=True,
        )
        wid = win.stdout.strip()
        if not wid:
            return ""
        res = subprocess.run(
            ["xprop", "-id", wid, "WM_CLASS"], capture_output=True, text=True,
        )
        return res.stdout.lower()
    except OSError:
        return ""


def unwrap_text(text):
    """Undo PDF-style hard line wrapping so TTS doesn't pause mid-sentence.

    PDFs end every visual line with a newline; edge-tts treats each as a clause
    break, so a single sentence is read in choppy fragments. Join soft-wrapped
    lines back into spaces while keeping real paragraph breaks (blank lines) as
    a single pause.
    """
    # Re-join words split across a line break: "exam-\nple" -> "example".
    text = re.sub(r"(\w)-\n(\w)", r"\1\2", text)
    # Protect paragraph breaks (a blank line) with a sentinel before unwrapping.
    para = "\x00"
    text = re.sub(r"\n[ \t]*\n+", para, text)
    # A lone newline within a paragraph is a soft wrap -> space.
    text = re.sub(r"\s*\n\s*", " ", text)
    # Restore paragraph breaks as real newlines (a natural TTS pause).
    text = text.replace(para, "\n")
    # Collapse runs of spaces/tabs left behind.
    text = re.sub(r"[ \t]+", " ", text)
    return text.strip()


def get_text(argv):
    if argv == ["-"]:
        return sys.stdin.read()
    if argv:
        return " ".join(argv)
    # No args: read the highlighted text. Most apps put it in the X PRIMARY
    # selection, but some copy the selection to the CLIPBOARD instead (e.g.
    # zathura with "set selection-clipboard clipboard"). PRIMARY is almost never
    # empty on a live session (it holds the last thing highlighted anywhere), so
    # we can't just fall back on emptiness -- we'd return stale PRIMARY and never
    # see the fresh CLIPBOARD text. Instead, when the focused window is one of
    # those clipboard-copying apps, try CLIPBOARD first.
    if not which("xclip"):
        notify("xclip not installed (needed to read the selection)", "critical")
        sys.exit(1)
    sels = ("primary", "clipboard")
    if "zathura" in active_window_class():
        sels = ("clipboard", "primary")
    for sel in sels:
        res = subprocess.run(
            ["xclip", "-selection", sel, "-o"],
            capture_output=True, text=True,
        )
        if res.stdout.strip():
            return res.stdout
    return ""


def main(argv):
    # Pull leading flags off the argument list; the rest is text to speak.
    unwrap = False
    args = []
    for a in argv:
        if a in ("-u", "--unwrap"):
            unwrap = True
        else:
            args.append(a)

    # Toggle: a bare keypress while talking just stops playback.
    was_speaking = stop_if_speaking()
    if was_speaking and not args:
        return

    for dep in ("edge-tts", "mpv"):
        if not which(dep):
            notify(f"{dep} not found in PATH", "critical")
            sys.exit(1)

    text = get_text(args)
    if unwrap:
        text = unwrap_text(text)
    text = text.strip()
    if not text:
        notify("Nothing selected to speak")
        return

    # Stream edge-tts' mp3 straight into mpv. The text is passed via the
    # environment, not the command line, so a selection containing quotes,
    # $(...) or backticks can't break quoting or inject shell commands.
    env = {**os.environ, "SPEAK_TEXT": text, "SPEAK_VOICE": VOICE}
    proc = subprocess.Popen(
        'edge-tts --voice "$SPEAK_VOICE" --text "$SPEAK_TEXT" '
        '| mpv --no-terminal --really-quiet --no-video -',
        shell=True, start_new_session=True, env=env,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    PIDFILE.write_text(str(proc.pid))


if __name__ == "__main__":
    main(sys.argv[1:])
