#!/usr/bin/env python3
"""Shorten a URL via tinyurl.fftp.io."""

import argparse
import os
import subprocess
import sys
import json

SHORTEN_URL = "https://tinyurl.fftp.io/api/shorten"
API_KEY_FILE = os.path.expanduser("~/.config/tinyurl/api_key")


def _read_api_key():
    try:
        with open(API_KEY_FILE) as f:
            return f.read().strip()
    except FileNotFoundError:
        print(f"Error: API key not found at {API_KEY_FILE}", file=sys.stderr)
        sys.exit(1)


def copy_to_clipboard(text):
    try:
        subprocess.run(["xclip", "-selection", "clipboard"], input=text, text=True)
    except FileNotFoundError:
        pass


def shorten_url(url):
    api_key = _read_api_key()
    cmd = [
        "curl", "-fsS",
        "--connect-timeout", "5",
        "--max-time", "10",
        "-H", f"Authorization: Bearer {api_key}",
        "-H", "Content-Type: application/json",
        "-d", json.dumps({"url": url}),
        SHORTEN_URL,
    ]

    try:
        result = subprocess.run(cmd, capture_output=True, text=True)
        if result.returncode == 0 and result.stdout.strip():
            data = json.loads(result.stdout.strip())
            return data.get("short_url")
        return None
    except (subprocess.TimeoutExpired, FileNotFoundError, json.JSONDecodeError):
        return None


def main():
    parser = argparse.ArgumentParser(description="Shorten a URL via tinyurl.fftp.io")
    parser.add_argument("url", help="URL to shorten")
    args = parser.parse_args()

    if not args.url.startswith(("http://", "https://")):
        print("Error: URL must start with http:// or https://", file=sys.stderr)
        sys.exit(1)

    short_url = shorten_url(args.url)

    if short_url:
        copy_to_clipboard(short_url)
        print(short_url)
    else:
        print("Error: failed to shorten URL", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
