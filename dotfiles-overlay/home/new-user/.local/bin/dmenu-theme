#!/bin/sh

# Load dmenu configuration
[ -f "$HOME/.config/dmenu/config" ] && . "$HOME/.config/dmenu/config"

# Define options
CHOICE=$(printf '%s\n' "Toggle" "Light" "Dark" | dmenu $DMENU_BASIC_ARGS -fn "$DMENU_FONT" -p "Theme:")

# Execute theme command based on choice
case "$CHOICE" in
    Toggle)
        theme --toggle
        ;;
    Light)
        theme --light
        ;;
    Dark)
        theme --dark
        ;;
esac
