#!/usr/bin/env python3
import os
import re
import subprocess
import sys
import glob
import json
import random
try:
    from urllib.request import urlopen, Request
    from urllib.error import URLError
except ImportError:
    pass

DMENU_CONFIG_PATH = os.path.expanduser("~/.config/dmenu/config")
WG_DIR = "/etc/wireguard"
MULLVAD_API = "https://api.mullvad.net/www/relays/wireguard/"
MULLVAD_CONF = os.path.join(WG_DIR, "mullvad.conf")
LOG_FILE = "/tmp/dmenu-vpn.log"


def log(msg):
    from datetime import datetime
    try:
        with open(LOG_FILE, "a") as f:
            f.write(f"[{datetime.now().isoformat()}] {msg}\n")
    except Exception:
        pass


def notify(title, msg):
    log(f"{title}: {msg}")
    subprocess.run(["notify-send", title, msg])


def get_dmenu_args():
    dmenu_args = []
    font = ""
    if os.path.exists(DMENU_CONFIG_PATH):
        with open(DMENU_CONFIG_PATH, "r") as f:
            for line in f:
                line = line.strip()
                if line.startswith("DMENU_BASIC_ARGS="):
                    match = re.search(r'DMENU_BASIC_ARGS="([^"]+)"', line)
                    if match:
                        dmenu_args = match.group(1).split()
                elif line.startswith("DMENU_FONT="):
                    match = re.search(r'DMENU_FONT="([^"]+)"', line)
                    if match:
                        font = match.group(1)
    cmd = ["dmenu"] + dmenu_args
    if font:
        cmd.extend(["-fn", font])
    cmd.extend(["-i", "-p"])
    return cmd


def run_dmenu(options, prompt):
    cmd = get_dmenu_args() + [prompt]
    try:
        p = subprocess.Popen(cmd, stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        stdout, _ = p.communicate(input="\n".join(options).encode("utf-8"))
        return stdout.decode("utf-8").strip()
    except FileNotFoundError:
        notify("Error", "dmenu not found")
        sys.exit(1)


def is_connected(interface="mullvad"):
    result = subprocess.run(["sudo", "-n", "wg", "show", interface], capture_output=True)
    return result.returncode == 0



def get_configs():
    """Find all .conf files in /etc/wireguard/"""
    try:
        confs = subprocess.run(
            ["sudo", "-n", "ls", WG_DIR],
            capture_output=True, text=True
        )
        if confs.returncode != 0:
            return []
        return [f.replace(".conf", "") for f in confs.stdout.strip().split("\n") if f.endswith(".conf")]
    except Exception:
        return []


def vpn_up(interface):
    result = subprocess.run(["sudo", "-n", "wg-quick", "up", interface], capture_output=True, text=True)
    if result.returncode == 0:
        notify("VPN", f"Connected to {interface}")
        subprocess.run(["polybar-msg", "action", "vpn", "hook", "0"])
    else:
        notify("VPN", f"Failed to connect: {result.stderr.strip()}")



def vpn_down(interface):
    result = subprocess.run(["sudo", "-n", "wg-quick", "down", interface], capture_output=True, text=True)
    if result.returncode == 0:
        notify("VPN", f"Disconnected from {interface}")
        subprocess.run(["polybar-msg", "action", "vpn", "hook", "0"])
    else:
        notify("VPN", f"Failed to disconnect: {result.stderr.strip()}")


def fetch_servers():
    """Fetch Mullvad WireGuard server list from public API"""
    try:
        req = Request(MULLVAD_API, headers={"User-Agent": "dmenu-vpn/1.0"})
        with urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode())
    except Exception as e:
        notify("VPN", f"Failed to fetch servers: {e}")
        return []


def read_current_config():
    """Read PrivateKey and Address from user-owned identity file"""
    identity_path = os.path.expanduser("~/.config/mullvad/identity.conf")
    try:
        with open(identity_path, "r") as f:
            content = f.read()
    except FileNotFoundError:
        notify("VPN", f"Identity file not found: {identity_path}")
        return None, None
    private_key = None
    address = None
    for line in content.splitlines():
        line = line.strip()
        if line.startswith("PrivateKey"):
            private_key = line.split("=", 1)[1].strip()
        elif line.startswith("Address"):
            address = line.split("=", 1)[1].strip()
    return private_key, address


def build_config(private_key, address, peer_pubkey, endpoint):
    """Build a mullvad.conf string"""
    return f"""[Interface]
PrivateKey = {private_key}
Address = {address}
DNS = 10.64.0.1
PostUp = systemctl stop tailscaled
PostDown = systemctl start tailscaled

[Peer]
PublicKey = {peer_pubkey}
AllowedIPs = 0.0.0.0/0,::0/0
Endpoint = {endpoint}:51820
"""


def change_location():
    """Let user pick a Mullvad server city, rewrite config, and connect"""
    # Read identity (no sudo needed)
    private_key, address = read_current_config()
    if not private_key or not address:
        notify("VPN", "Cannot read existing config (PrivateKey/Address missing)")
        return

    notify("VPN", "Fetching server list...")
    servers = fetch_servers()
    if not servers:
        return

    # Group active servers by "Country — City"
    cities = {}
    for s in servers:
        if not s.get("active", False):
            continue
        label = f"{s['country_name']} — {s['city_name']}"
        cities.setdefault(label, []).append(s)

    sorted_cities = sorted(cities.keys())

    choice = run_dmenu(sorted_cities, "Location:")
    if not choice or choice not in cities:
        return

    server = random.choice(cities[choice])

    # Disconnect if currently connected
    if is_connected("mullvad"):
        vpn_down("mullvad")

    # Write config to temp file (no sudo needed)
    config = build_config(private_key, address, server["pubkey"], server["ipv4_addr_in"])
    tmp_path = os.path.expanduser("~/.config/mullvad/mullvad-next.conf")
    with open(tmp_path, "w") as f:
        f.write(config)

    # Copy config into place (separate sudo call — sh -c fails without a terminal)
    notify("VPN", f"Switching to {choice} ({server['hostname']})")
    cp_result = subprocess.run(
        ["sudo", "-n", "/usr/bin/cp", tmp_path, MULLVAD_CONF],
        capture_output=True, text=True
    )
    os.unlink(tmp_path)

    if cp_result.returncode != 0:
        log(f"sudo cp failed (rc={cp_result.returncode})")
        log(f"stderr: {cp_result.stderr}")
        notify("VPN", f"Failed to write config: {cp_result.stderr.strip()}")
        return

    vpn_up("mullvad")


def main():
    configs = get_configs()
    if not configs:
        configs = ["mullvad"]

    # Check which interfaces are currently active
    active = [c for c in configs if is_connected(c)]

    options = []

    # Offer connections to inactive configs first
    inactive = [c for c in configs if c not in active]
    for c in inactive:
        options.append(f"Connect {c}")

    if active:
        status = ", ".join(active)
        for a in active:
            options.append(f"Disconnect {a}")
        options.append(f"Status [{status}]")
    else:
        options.append("Status [OFF]")

    options.append("Change Location")

    choice = run_dmenu(options, "VPN:")
    if not choice:
        return

    if choice == "Change Location":
        change_location()
    elif choice.startswith("Connect "):
        interface = choice.replace("Connect ", "")
        vpn_up(interface)
    elif choice.startswith("Disconnect "):
        interface = choice.replace("Disconnect ", "")
        vpn_down(interface)
    elif choice.startswith("Status"):
        if active:
            notify("VPN", f"Connected to: {', '.join(active)}")
        else:
            notify("VPN", "Not connected")


if __name__ == "__main__":
    main()
