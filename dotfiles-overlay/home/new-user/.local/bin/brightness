#!/usr/bin/env python3
"""brightness - Show or set the display backlight brightness.

Usage:
  brightness            Show the current brightness percentage.
  brightness 50         Set the brightness to 50%.
  brightness +10        Increase the brightness by 10 percentage points.
  brightness -10        Decrease the brightness by 10 percentage points.

A trailing '%' is accepted and ignored (e.g. 'brightness 50%').
The brightness is clamped to the range [MIN_PERCENT, 100] so the panel
never goes fully black.
"""

import os
import re
import subprocess
import sys
from pathlib import Path
from shutil import which

# If running inside a distrobox container, re-exec on the host so we touch
# the host's backlight rather than a (non-existent) one inside the container.
if os.path.exists("/run/.containerenv"):
    if which("distrobox-host-exec"):
        os.execvp("distrobox-host-exec", ["distrobox-host-exec"] + sys.argv)

# Lowest brightness we will ever set; keeps the screen from blacking out.
MIN_PERCENT = 5

BACKLIGHT_ROOT = Path("/sys/class/backlight")


def die(msg):
    print(f"brightness: {msg}", file=sys.stderr)
    sys.exit(1)


def find_device():
    """Return the path of the backlight device to control."""
    try:
        devices = sorted(p for p in BACKLIGHT_ROOT.iterdir())
    except FileNotFoundError:
        die("no backlight interface found (/sys/class/backlight is missing)")
    if not devices:
        die("no backlight devices found under /sys/class/backlight")
    # Prefer a real panel backlight over LED/keyboard interfaces if present.
    for dev in devices:
        if (dev / "max_brightness").exists():
            return dev
    return devices[0]


def read_int(path):
    return int(path.read_text().strip())


def get_percent(dev):
    """Return the current brightness as an integer percentage."""
    # actual_brightness reflects the hardware; brightness is the last request.
    cur_path = dev / "actual_brightness"
    if not cur_path.exists():
        cur_path = dev / "brightness"
    cur = read_int(cur_path)
    maximum = read_int(dev / "max_brightness")
    return round(cur * 100 / maximum)


def set_percent(dev, percent):
    """Set the brightness to the given (already validated) percentage."""
    percent = max(MIN_PERCENT, min(100, percent))
    maximum = read_int(dev / "max_brightness")
    raw = round(percent * maximum / 100)
    raw = max(1, min(maximum, raw))

    # Prefer brightnessctl: it has the udev rules to write without root.
    if which("brightnessctl"):
        rc = subprocess.run(
            ["brightnessctl", "--device", dev.name, "set", str(raw)],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        ).returncode
        if rc == 0:
            return percent
        # Fall through to a direct write if brightnessctl failed.

    try:
        (dev / "brightness").write_text(str(raw))
    except PermissionError:
        die(
            "permission denied writing brightness; install brightnessctl or "
            "add your user to the 'video' group"
        )
    except OSError as e:
        die(f"failed to set brightness: {e}")
    return percent


def main(argv):
    if argv and argv[0] in ("-h", "--help"):
        print(__doc__.strip())
        return

    dev = find_device()

    if not argv:
        print(f"{get_percent(dev)}%")
        return

    if len(argv) > 1:
        die("too many arguments (expected a single value)")

    arg = argv[0].strip().rstrip("%")
    m = re.fullmatch(r"([+-]?)(\d+)", arg)
    if not m:
        die(f"invalid value: {argv[0]!r} (expected e.g. 50, +10, -10)")

    sign, digits = m.group(1), int(m.group(2))
    if sign:
        target = get_percent(dev) + (digits if sign == "+" else -digits)
    else:
        target = digits

    result = set_percent(dev, target)
    print(f"{result}%")


if __name__ == "__main__":
    main(sys.argv[1:])
