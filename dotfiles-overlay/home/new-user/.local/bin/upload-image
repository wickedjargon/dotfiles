#!/usr/bin/env python3
"""Upload an image file. Uses upload-u (u.fftp.io) by default."""

import os
import subprocess
import sys


def main():
    if len(sys.argv) < 2:
        print(f"Usage: {os.path.basename(sys.argv[0])} <file> [args...]", file=sys.stderr)
        sys.exit(1)

    # Pass through to upload-u
    script_dir = os.path.dirname(os.path.abspath(__file__))
    upload_u = os.path.join(script_dir, "upload-u")
    os.execv(upload_u, [upload_u] + sys.argv[1:])


if __name__ == "__main__":
    main()
