# bash completion for wifi
_wifi() {
    local cur prev
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    # Complete subcommands at position 1
    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=( $(compgen -W "list connect disconnect reconnect saved forget password rescan toggle help --help" -- "$cur") )
        return
    fi

    local cmd="${COMP_WORDS[1]}"

    case "$cmd" in
        connect)
            # Suggest available SSIDs. nmcli -t escapes ':' and '\' as '\:'
            # and '\\'; the sed undoes that so the real SSID is offered.
            local -a ssid_list
            mapfile -t ssid_list < <(nmcli -t -f SSID device wifi list 2>/dev/null | sed 's/\\\(.\)/\1/g' | grep -v '^$' | sort -u)
            _wifi_complete_names "${ssid_list[@]}"
            ;;
        forget|password)
            # Suggest saved WiFi connection names (strip the TYPE suffix, then
            # un-escape nmcli -t's '\:' / '\\').
            local -a saved_list
            mapfile -t saved_list < <(nmcli -t -f NAME,TYPE connection show 2>/dev/null | sed -n 's/:802-11-wireless$//p' | sed 's/\\\(.\)/\1/g')
            _wifi_complete_names "${saved_list[@]}"
            ;;
    esac
}

# Helper: populate COMPREPLY from a set of names, preserving spaces/quotes.
# Matches manually rather than via `compgen -W`, which would word-split AND
# *expand* each name — an SSID literally named $(...) or `...` would execute
# on TAB (SSIDs are attacker-controlled). $cur is dequoted (leading quote
# stripped, backslashes dropped) so `Foo\ Bar` and "Foo Bar" both match;
# raw names go into COMPREPLY and -o filenames escapes them on insertion.
_wifi_complete_names() {
    local name q="${cur#[\"\']}"
    q="${q//\\/}"
    COMPREPLY=()
    for name in "$@"; do
        [ -n "$name" ] || continue
        [[ "$name" == "$q"* ]] && COMPREPLY+=( "$name" )
    done
    [ ${#COMPREPLY[@]} -gt 0 ] && compopt -o filenames 2>/dev/null
}

complete -F _wifi wifi
