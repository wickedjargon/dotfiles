# bash completion for rss
_rss() {
    local cur prev
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    # Complete subcommands at position 1
    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=( $(compgen -W "add del fetch read catchup reset list export import help --help" -- "$cur") )
        return
    fi

    local cmd="${COMP_WORDS[1]}"

    # Dynamic feed name completion from feeds.opml
    _rss_feed_names() {
        local opml="$HOME/.local/share/rss/feeds.opml"
        if [ -f "$opml" ]; then
            grep -oP 'text="\K[^"]+' "$opml" 2>/dev/null
        fi
    }

    case "$cmd" in
        del|read|fetch|catchup)
            # Complete with feed names, case-insensitively. Dequote $cur
            # (strip a leading quote, drop backslash escapes) so both
            # `rss read Foo\ Bar` and `rss read "Foo Bar"` match; emit raw
            # names and let -o filenames escape the spaces on insertion.
            local q="${cur#[\"\']}"
            q="${q//\\/}"
            COMPREPLY=()
            while IFS= read -r name; do
                [ -z "$name" ] && continue
                if [[ "${name,,}" == "${q,,}"* ]]; then
                    COMPREPLY+=( "$name" )
                fi
            done < <(_rss_feed_names)
            [ ${#COMPREPLY[@]} -gt 0 ] && compopt -o filenames 2>/dev/null
            ;;
        add)
            # No special completion for URLs
            ;;
        import)
            # File completion for OPML files (handles spaces/escaping)
            if declare -F _filedir >/dev/null; then
                _filedir
            else
                COMPREPLY=( $(compgen -f -- "$cur") )
            fi
            ;;
    esac
}

complete -o default -F _rss rss
