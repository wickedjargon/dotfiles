# bash completion for bt
_bt() {
    local cur prev
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    # Complete subcommands at position 1
    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=( $(compgen -W "connect disconnect reconnect profile profiles battery toggle scan pair remove list help --help" -- "$cur") )
        return
    fi

    local cmd="${COMP_WORDS[1]}"

    case "$cmd" in
        connect)
            # Suggest paired but disconnected device names
            local devs
            devs=$(bluetoothctl devices 2>/dev/null | sed 's/^Device [0-9A-F:]* //')
            _bt_complete_names "$devs"
            ;;
        disconnect|reconnect|battery)
            # Suggest connected device names
            local devs
            devs=$(bluetoothctl devices Connected 2>/dev/null | sed 's/^Device [0-9A-F:]* //')
            _bt_complete_names "$devs"
            ;;
        remove)
            # Suggest all paired device names
            local devs
            devs=$(bluetoothctl devices 2>/dev/null | sed 's/^Device [0-9A-F:]* //')
            _bt_complete_names "$devs"
            ;;
        profile)
            # At position 2 (the profile), suggest profiles from pactl
            if [ "$COMP_CWORD" -eq 2 ]; then
                local profiles
                profiles=$(pactl list cards 2>/dev/null | grep -A1 '^\s*Profiles:' | sed -n 's/^\t\t\(\S\+\):.*/\1/p' 2>/dev/null | grep -v '^off$')
                [ -z "$profiles" ] && profiles="a2dp-sink headset-head-unit"
                COMPREPLY=( $(compgen -W "$profiles" -- "$cur") )
            else
                # At position 3+, suggest connected devices
                local devs
                devs=$(bluetoothctl devices Connected 2>/dev/null | sed 's/^Device [0-9A-F:]* //')
                _bt_complete_names "$devs"
            fi
            ;;
    esac
}

# Helper: populate COMPREPLY from a newline-separated list of device names,
# preserving spaces/quotes. Matches manually rather than via `compgen -W`,
# which would word-split AND *expand* each name — a device named $(...) or
# `...` would execute on TAB (Bluetooth names are attacker-controlled).
# $cur is dequoted so both `bt connect Foo\ Bar` and "Foo Bar" match; raw
# names go into COMPREPLY and -o filenames escapes them on insertion.
_bt_complete_names() {
    local name q="${cur#[\"\']}"
    q="${q//\\/}"
    COMPREPLY=()
    while IFS= read -r name; do
        [ -n "$name" ] || continue
        [[ "$name" == "$q"* ]] && COMPREPLY+=( "$name" )
    done <<< "$1"
    [ ${#COMPREPLY[@]} -gt 0 ] && compopt -o filenames 2>/dev/null
}

complete -F _bt bt
