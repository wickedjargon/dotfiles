# bash completion for upload
_upload() {
    local cur prev
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    # Complete subcommands at position 1
    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=( $(compgen -W "file selection help --help" -- "$cur") )
        return
    fi

    local cmd="${COMP_WORDS[1]}"

    # Complete --backend values
    if [ "$prev" = "--backend" ]; then
        COMPREPLY=( $(compgen -W "0x0 u" -- "$cur") )
        return
    fi

    case "$cmd" in
        file)
            # Flags when the user is typing one, otherwise file completion
            # (_filedir handles spaces/escaping for both quote styles).
            if [[ "$cur" == -* ]]; then
                COMPREPLY=( $(compgen -W "--backend --preserve-filename --keep-exif" -- "$cur") )
            elif declare -F _filedir >/dev/null; then
                _filedir
            else
                COMPREPLY=( $(compgen -f -- "$cur") )
            fi
            ;;
        selection)
            COMPREPLY=( $(compgen -W "--backend" -- "$cur") )
            ;;
    esac
}

complete -o default -F _upload upload
