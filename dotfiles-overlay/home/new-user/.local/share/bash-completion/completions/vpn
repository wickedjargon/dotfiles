# bash completion for vpn
_vpn() {
    local cur prev
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    if [ "$COMP_CWORD" -eq 1 ]; then
        COMPREPLY=( $(compgen -W "connect disconnect location list refresh help --help" -- "$cur") )
        return
    fi

    local cmd="${COMP_WORDS[1]}"
    case "$cmd" in
        connect|location)
            # Suggest cached country/city codes
            if [ -f "$HOME/.cache/mullvad-relays.json" ]; then
                local locations
                locations=$(python3 -c "
import json, sys
try:
    data = json.load(open('$HOME/.cache/mullvad-relays.json'))
    seen = set()
    for r in data:
        for key in ('country_code', 'city_code', 'country_name'):
            v = r.get(key, '')
            if v and v.lower() not in seen:
                seen.add(v.lower())
                print(v)
except: pass
" 2>/dev/null)
                # Match manually (not `compgen -W`, which would expand each
                # name); keeps multi-word names like "New Zealand" intact and
                # escapes spaces on insert via -o filenames. $cur is dequoted
                # so `New\ Zealand` and "New Zealand" both match.
                local name q="${cur#[\"\']}"
                q="${q//\\/}"
                COMPREPLY=()
                while IFS= read -r name; do
                    [ -n "$name" ] || continue
                    [[ "$name" == "$q"* ]] && COMPREPLY+=( "$name" )
                done <<< "$locations"
                [ ${#COMPREPLY[@]} -gt 0 ] && compopt -o filenames 2>/dev/null
            fi
            ;;
    esac
}

complete -F _vpn vpn
