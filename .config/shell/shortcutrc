alias fff_screenkey="screenkey -t 0.2 --opacity 0.3"
alias fff_list_packages='expac -s "%-30n %m" | sort -rhk 2 | less' # list packages largest to smallest
alias fff_set_cursor_speed='xset r rate 300 50 &'
alias fff_generate_tags='find . -name "*.[chCH]" -print | etags -'
alias fff_invert_colors="xcalib -invert -alter"
alias fff_free_space="df -hl"
alias fff_remove_orphans="pacman -Qtdq | pacman -Rns -"
alias fff_books="em /home/ff/d/books/"
alias fff_calc="bc"
alias fff_remaps="source .local/bin/remaps"
alias fff_notification_history="dunstctl history"
alias fff_cal="calcurse -Q --from $(date +'%m/%d/%Y')"
alias fff_restart_emacs="killall emacs && emacs --daemon"

alias em="emacsclient -c"
alias m="emacsclient -c"
alias g="tuxi"
alias o="xdg-open"
alias classical="/home/ff/d/shell/classical.sh"
alias jazz="/home/ff/d/shell/jazz.sh"
alias c="codium"
alias code="code-insiders"
alias icaclient="/opt/Citrix/ICAClient/wfica"
alias qdirstat="qdirstat"
alias fff_groff="groff -ms test.ms -T pdf > test.pdf"
alias scheme="rlwrap mit-scheme"
alias gajim="GDK_DPI_SCALE=1.3 gajim"
