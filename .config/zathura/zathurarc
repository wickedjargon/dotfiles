set sandbox none
set statusbar-h-padding 0
set statusbar-v-padding 0
set page-padding 1
set selection-clipboard clipboard
set recolor true

map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map = zoom in
map - zoom out
map ii recolor
map q quit
map g goto top

set font "monospace 11"
